<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission
        android:name="android.permission.WRITE_SECURE_SETTINGS"
        tools:ignore="ProtectedPermissions" />
    <uses-permission
        android:name="android.permission.QUERY_ADVANCED_PROTECTION_MODE"
        tools:ignore="UnknownPermission" />
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />

    <!--
        Deliberately no INTERNET permission. OpenLumen is fully offline, F-Droid clean.
        No crash reporting, no remote config, no telemetry. Ever.
    -->

    <uses-feature android:name="android.hardware.sensor.light" android:required="false" />

    <application
        android:name=".OpenLumenApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.OpenLumen"
        android:directBootAware="true"
        tools:targetApi="35">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.OpenLumen">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".service.LumenService"
            android:directBootAware="true"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Persistent display color tint for eye comfort and sleep hygiene." />
        </service>

        <service
            android:name=".service.LumenTileService"
            android:exported="true"
            android:icon="@drawable/ic_lumen_tile"
            android:label="@string/app_name"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <!--
                Long-press destination for the QS tile. Android routes the
                long-press intent to this activity instead of generic App Info.
                Honored on API 24+; OpenLumen's minSdk is 26 so this is always
                effective. Tied to roadmap candidate C17.
            -->
            <meta-data
                android:name="android.service.quicksettings.PREFERENCES_ACTIVITY"
                android:value="com.openlumen.MainActivity" />
        </service>

        <receiver
            android:name=".service.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".service.LockedBootReceiver"
            android:directBootAware="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.LOCKED_BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".service.ScheduleAlarmReceiver"
            android:exported="false" />

        <receiver
            android:name=".service.AutomationReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.openlumen.action.TURN_OFF" />
                <action android:name="com.openlumen.action.TURN_ON" />
                <action android:name="com.openlumen.action.TOGGLE" />
                <action android:name="com.openlumen.action.REEVALUATE" />
                <action android:name="com.openlumen.action.CYCLE_PRESET" />
                <action android:name="com.openlumen.action.SET_PRESET" />
                <action android:name="com.openlumen.action.RESTORE_PREVIOUS" />
                <action android:name="com.openlumen.action.SET_INTENSITY" />
                <action android:name="com.openlumen.action.SET_DIM" />
            </intent-filter>
        </receiver>

        <receiver
            android:name=".widget.WidgetActionReceiver"
            android:exported="false" />

        <!--
            WorkManager (pulled in transitively by Glance) auto-initializes
            via androidx.startup at process start. On a directBootAware
            Application, that fires before the context's storage paths have
            settled to credential-protected mode, and Room blows up
            constructing WorkDatabase on some Android 10 devices (see
            issue #5: Galaxy S9+ / Android 10). We disable the startup
            initializer and let WorkManager lazy-init via our
            Configuration.Provider when Glance first enqueues work, which
            only happens post-unlock.
        -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!--
            1x1 toggle widget (roadmap C19/C123). Glance renders the
            widget; ACTION_REFRESH still lets LumenService nudge all
            instances after each prefs emission.
        -->
        <receiver
            android:name=".widget.ToggleWidget"
            android:exported="false"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.openlumen.widget.action.REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_toggle_info" />
        </receiver>

        <!--
            4x1 preset widget (roadmap C20/C123). Glance renders the
            first four favorited presets as tappable chips. Uses an
            action-namespaced refresh broadcast so it doesn't fight
            ToggleWidget's intent filter.
        -->
        <receiver
            android:name=".widget.PresetWidget"
            android:exported="false"
            android:label="@string/app_name">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
                <action android:name="com.openlumen.widget.action.PRESET_REFRESH" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/widget_preset_info" />
        </receiver>

    </application>
</manifest>
