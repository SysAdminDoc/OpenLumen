<?xml version="1.0" encoding="utf-8"?>
<!--
    4x1 preset widget. Tied to roadmap candidate C20.

    Four slot containers in a horizontal row; each contains a small colored
    swatch (tinted at runtime to the preset's RGB) and the preset name
    underneath. If the user has fewer than four favorites, the unused slots
    are GONE and a hint TextView in the center reminds them to mark favorites
    in the app.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="6dp"
    android:background="@drawable/widget_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="4">

        <LinearLayout
            android:id="@+id/widget_preset_slot0"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">
            <ImageView
                android:id="@+id/widget_preset_swatch0"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/widget_swatch_circle" />
            <TextView
                android:id="@+id/widget_preset_label0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:singleLine="true"
                android:textSize="10sp"
                android:text="" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_preset_slot1"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">
            <ImageView
                android:id="@+id/widget_preset_swatch1"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/widget_swatch_circle" />
            <TextView
                android:id="@+id/widget_preset_label1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:singleLine="true"
                android:textSize="10sp"
                android:text="" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_preset_slot2"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">
            <ImageView
                android:id="@+id/widget_preset_swatch2"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/widget_swatch_circle" />
            <TextView
                android:id="@+id/widget_preset_label2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:singleLine="true"
                android:textSize="10sp"
                android:text="" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_preset_slot3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="4dp">
            <ImageView
                android:id="@+id/widget_preset_swatch3"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@null"
                android:src="@drawable/widget_swatch_circle" />
            <TextView
                android:id="@+id/widget_preset_label3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:singleLine="true"
                android:textSize="10sp"
                android:text="" />
        </LinearLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/widget_preset_hint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center"
        android:padding="8dp"
        android:textSize="11sp"
        android:singleLine="true"
        android:text="@string/widget_preset_hint"
        android:visibility="gone" />

</FrameLayout>
