<?xml version="1.0" encoding="utf-8"?>
<!--
    Android 12+ backup and device-transfer scope.
    Include-only list: ONLY these paths are backed up / transferred.

    Included:
      datastore/  — user preferences (filter, schedule, profiles)
      sharedpref/ — notification-prompt one-shot flags

    Excluded by omission:
      crash.log        — device-local crash log, per privacy policy
      diagnostics.log  — device-local event log, per privacy policy

    Note: ScheduleDto.latitude/longitude (user-entered approximate city
    coordinates from the ~95-city picker) are part of the DataStore
    preferences blob and are intentionally included so solar schedule
    survives restore.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="datastore/" />
        <include domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="datastore/" />
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
